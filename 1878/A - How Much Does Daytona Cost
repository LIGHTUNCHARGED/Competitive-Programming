//  A. How Much Does Daytona Cost?
 
#include<bits/stdc++.h>
 
using namespace std;
 
int main() {
    int t; cin>>t;
    while (t--) {
        int n, k; cin>>n>>k;
        bool exists = false;
        for (int i = 0; i < n; i++) {
            int num; cin>>num;
            if (num == k) {
                exists = true;
            }
        }
        exists ? cout<<"Yes" : cout<<"No";
        cout<<endl;
 
    }
    
    return 0;
}